@model IEnumerable<disco_app_MVC.Models.Dominio.Disco>

@{
    ViewData["Title"] = "Listado Discos";
}

<h1>Catálogo de Discos</h1>

<p>
    <a class="btn btn-primary" asp-action="Create">Agregar Nuevo</a>
</p>
<form asp-action="Index" method="get">
    <div class="row">
        <div class="col-10">
            <input value="@ViewBag.Filtro" class="form-control" type="text" name="filtro" placeholder="Buscar por nombre..."/>
        </div>
        <div class="col-2">
            <button class="btn btn-outline-success">Buscar</button>
        </div>
    </div>
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Titulo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CantidadCanciones)
            </th>
            <th>
                Tapa de Disco
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TipoEdicion)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Titulo)
            </td>
            <td>
                @Html.DisplayFor(model => item.CantidadCanciones)
            </td>
            <td>
                <img src="@item.UrlTapa" height="50"/>
            </td>
            <td>
                @Html.DisplayFor(model => item.TipoEdicion.Descripcion)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">Editar</a> |
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-success">Detalle</a> |
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Eliminar</a>
            </td>
        </tr>
}
    </tbody>
</table>
